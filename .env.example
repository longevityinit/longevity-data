# Copy this file to `.env` and fill in real values. The .env file itself
# is gitignored.

# --- Remote object storage (Backblaze B2 or any S3-compatible service) ---
# Used by scripts/utils/storage.py to mirror downloaded snapshots.
B2_BUCKET_NAME=
B2_ENDPOINT_URL=
B2_KEY_ID=
B2_APPLICATION_KEY=

# --- Human Mortality Database (https://www.mortality.org) ---
# Register at https://www.mortality.org/Account/UserAgreement to obtain
# credentials. Used by scripts/utils/hmd.py.
HMD_EMAIL=
HMD_PASSWORD=
